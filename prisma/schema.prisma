generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// AUTH & USERS
// ==========================================
model User {
  id                  String    @id @default(uuid())
  name                String    @default("")
  email               String    @unique
  password            String
  role                String    @default("AUTHOR") // SUPER_ADMIN, ADMIN, AUTHOR
  isVerified          Boolean   @default(true)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  recoveryCodes       String?   // JSON array of recovery codes
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  otpCode             String?
  otpExpiry           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Blog system removed to optimize speed and bundle size.

// ==========================================
// SITE SETTINGS (singleton)
// ==========================================
model SiteSettings {
  id            String  @id @default("default")
  siteName      String  @default("Anti Gravity 2.0")
  siteTagline   String  @default("AI-Powered Blogging Platform")
  adminEmail    String  @default("admin@antigravity.com")
  aiProvider    String  @default("openai")    // openai, gemini, anthropic, deepseek
  aiApiKey      String  @default("")
  aiModel       String  @default("gpt-4o-mini")
  aiContext     String? @default("")
  seoTitle      String  @default("Anti Gravity 2.0 | AI-Powered Blog")
  seoDescription String @default("Advanced AI-Powered Blogging Platform")
  updatedAt     DateTime @updatedAt
}

// ==========================================
// LEAD GENERATION
// ==========================================
model Lead {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  website   String?
  message   String?
  source    String    @default("blog_form")  // blog_form, chatbot, popup, banner
  status    String    @default("New")        // New, Contacted, Converted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==========================================
// SOCIAL LINKS (Smart Banners)
// ==========================================
model SocialLink {
  id           String   @id @default(uuid())
  platform     String   // whatsapp, telegram, instagram, phone, email
  label        String   @default("")
  url          String
  imageUrl     String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// AD MANAGEMENT (AdSense)
// ==========================================
model AdPlacement {
  id          String   @id @default(uuid())
  name        String
  position    String   // header, sidebar, in_content, footer
  adCode      String   // The full ad script/code
  publisherId String?  // AdSense publisher ID
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// EMAIL HUB & CAMPAIGNS
// ==========================================
model EmailSettings {
  id          String   @id @default("default")
  imapHost    String   @default("imap.gmail.com")
  imapPort    Int      @default(993)
  smtpHost    String   @default("smtp.gmail.com")
  smtpPort    Int      @default(465)
  emailUser   String   @default("")
  appPassword String   @default("")
  updatedAt   DateTime @updatedAt
}

model InboxMessage {
  id        String   @id @default(uuid())
  messageId String   @unique
  subject   String?
  from      String
  to        String
  date      DateTime
  text      String?
  html      String?
  isRead    Boolean  @default(false)
  isReplied Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Campaign {
  id        String   @id @default(uuid())
  name      String
  target    String   @default("no_website")
  status    String   @default("draft") // draft, sending, completed
  sentCount Int      @default(0)
  totalCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// EXISTING MODELS (preserved)
// ==========================================
model ApiKey {
  id        String   @id @default(uuid())
  name      String
  provider  String
  apiKey    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String?
  imageUrl    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Portfolio {
  id          String   @id @default(uuid())
  title       String
  category    String
  type        String
  imageUrl    String?
  websiteLink String?
  status      String   @default("Published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutreachMessage {
  id          String   @id @default(uuid())
  leadId      String
  channel     String
  subject     String?
  body        String
  status      String   @default("draft")
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebsiteAnalysis {
  id          String   @id @default(uuid())
  url         String
  report      String
  score       Int?
  createdAt   DateTime @default(now())
}

model AboutSetting {
  id          String   @id @default("default")
  heading     String   @default("About Us")
  content     String   @default("Welcome to our company.")
  mission     String?
  imageUrl    String?
  updatedAt   DateTime @updatedAt
}
